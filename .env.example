# Shared
ENVIRONMENT=local
LOG_LEVEL=INFO
AUTH_MODE=dev
DEV_AUTH_DEFAULT_EMAIL=dev@thesys.local
DEV_AUTH_DEFAULT_NAME=Dev User
NPM_REGISTRY=https://registry.npmjs.org/

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://thesys:thesys@localhost:5432/thesys
REDIS_URL=redis://localhost:6379/0
LITELLM_BASE_URL=http://localhost:4000

# Postgres
POSTGRES_DB=thesys
POSTGRES_USER=thesys
POSTGRES_PASSWORD=thesys

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=thesys-local

# LiteLLM
LITELLM_MASTER_KEY=sk-local-dev
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
