# Shared
ENVIRONMENT=local
LOG_LEVEL=INFO
AUTH_MODE=dev
DEV_AUTH_DEFAULT_EMAIL=dev@thesys.local
DEV_AUTH_DEFAULT_NAME=Dev User
NPM_REGISTRY=https://registry.npmjs.org/

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://thesys:thesys@localhost:5432/thesys
REDIS_URL=redis://localhost:6379/0
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-local-dev
LITELLM_MODEL=dev-local-qwen
LITELLM_TIMEOUT_SECONDS=180
LLM_STUB_MODE=always
LLM_STRUCTURED_OUTPUT_REPAIR_ATTEMPTS=1
LLM_FALLBACK_POLICY=emergency
OLLAMA_API_BASE=http://host.docker.internal:11434

# Local open-weight live mode
# Install Ollama on the host, run `ollama pull qwen2.5:3b`, then set:
# LLM_STUB_MODE=never
# LITELLM_MODEL=dev-local-qwen
# LITELLM_TIMEOUT_SECONDS=180
# LLM_STRUCTURED_OUTPUT_REPAIR_ATTEMPTS=1
# LLM_FALLBACK_POLICY=emergency

# OpenAI live-demo mode
# Use this only when you want MVP AI workflows to call OpenAI through LiteLLM.
# LLM_STUB_MODE=never
# OPENAI_API_KEY=<real provider key>
# LITELLM_MODEL=dev-gpt-4o-mini
# LITELLM_API_KEY=sk-local-dev
# LITELLM_MASTER_KEY=sk-local-dev

# Gemini live-demo mode
# Use Gemini 3.5 Flash through Google AI Studio.
# LLM_STUB_MODE=never
# GEMINI_API_KEY=<real provider key>
# LITELLM_MODEL=dev-gemini-3.5-flash
# LITELLM_API_KEY=sk-local-dev
# LITELLM_MASTER_KEY=sk-local-dev

# Postgres
POSTGRES_DB=thesys
POSTGRES_USER=thesys
POSTGRES_PASSWORD=thesys

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=thesys-local
OBJECT_STORAGE_MODE=s3
LOCAL_OBJECT_STORAGE_PATH=/tmp/thesys-object-storage
MAX_UPLOAD_MB=10
URL_FETCH_TIMEOUT_SECONDS=15

# Retrieval / embeddings
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=deterministic-hash-embedding-1536
EMBEDDING_DIMENSION=1536
EMBEDDING_VERSION=v1
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_RETRY_ATTEMPTS=1
RETRIEVAL_VECTOR_PATH=auto
RETRIEVAL_PYTHON_FALLBACK_ENABLED=true
RETRIEVAL_RERANKING_ENABLED=true
RETRIEVAL_RERANKER_PROVIDER=deterministic
RETRIEVAL_CONTEXT_TOKEN_BUDGET=3500
RETRIEVAL_MAX_CHUNKS_PER_SOURCE=2
RETRIEVAL_MIN_CONTEXT_SCORE=0.15

# External research connectors
# Disabled by default so local demos/tests do not call live search providers.
EXTERNAL_SEARCH_ENABLED=false
EXTERNAL_SEARCH_PROVIDER=deterministic
EXTERNAL_SEARCH_MAX_RESULTS_PER_QUERY=5
EXTERNAL_SEARCH_MAX_QUERIES_PER_SPRINT=6
EXTERNAL_SEARCH_TIMEOUT_SECONDS=20
TAVILY_API_KEY=

# Multimodal evidence extraction
# Images and low-text PDF fallback use deterministic fixture extraction locally.
MULTIMODAL_EXTRACTION_PROVIDER=deterministic
MULTIMODAL_EXTRACTION_MODEL=dev-gpt-4o-mini
MULTIMODAL_EXTRACTION_TIMEOUT_SECONDS=90
MULTIMODAL_PDF_FALLBACK_ENABLED=false
MULTIMODAL_PDF_MIN_TEXT_CHARS=80

# Live embedding mode through LiteLLM/OpenAI-compatible embeddings.
# After changing provider/model/dimension, re-embed existing project evidence.
# EMBEDDING_PROVIDER=litellm
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
# EMBEDDING_VERSION=openai-text-embedding-3-small-v1

# Optional live reranking through LiteLLM. Local tests and demos use the
# deterministic reranker by default.
# RETRIEVAL_RERANKER_PROVIDER=litellm

# Optional live Tavily search and LiteLLM-backed multimodal extraction.
# Source candidates still require human approval before ingestion.
# EXTERNAL_SEARCH_ENABLED=true
# EXTERNAL_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=<real Tavily key>
# MULTIMODAL_EXTRACTION_PROVIDER=litellm
# MULTIMODAL_EXTRACTION_MODEL=dev-gpt-4o-mini
# MULTIMODAL_PDF_FALLBACK_ENABLED=true

# LangSmith observability
# Leave disabled for local/offline development. Set LANGSMITH_TRACING=true and
# LANGSMITH_API_KEY to upload research sprint traces.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=thesys-local
LANGSMITH_PUBLIC_URL_BASE=https://smith.langchain.com

# Temporal durable orchestration
TEMPORAL_ENABLED=true
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=thesys-research-sprints
TEMPORAL_WORKFLOW_TIMEOUT_SECONDS=3600

# LiteLLM
LITELLM_MASTER_KEY=sk-local-dev
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
